{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lovable Blocks Manifest",
  "type": "object",
  "required": ["blocks"],
  "properties": {
    "blocks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["state"],
        "properties": {
          "state": {
            "type": "string",
            "enum": ["enabled", "stub", "disabled"]
          }
        },
        "additionalProperties": true
      }
    },
    "admin": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "customTabs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "route"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "route": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
