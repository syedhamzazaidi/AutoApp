# Platform builder — copy to .env: cp .env.example .env
#
# load-env.ts also reads repo root .env, so you can put these there instead.
# See ../../.env.sample for scaffold (Supabase) and other repo-wide vars.

# --- Server -------------------------------------------------------------------

# Port for landing page + builder (default 3001)
# PORT=3001


# --- Better Auth — Google OAuth for /builder ----------------------------------
#
# Required for Google sign-in on /builder and protected /api/* routes.
# Without these, the server logs warnings and sign-in will not work unless
# BUILDER_AUTH_DISABLED is set.
#
# 1. Generate BETTER_AUTH_SECRET:
#      openssl rand -base64 32
#
# 2. Create OAuth 2.0 credentials (Web application):
#      https://console.cloud.google.com/apis/credentials
#
# 3. Authorized redirect URI (must match BETTER_AUTH_URL):
#      http://localhost:3001/api/auth/callback/google
#    In production, use: https://your-domain/api/auth/callback/google

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local dev only — skip auth on /builder and protected API routes
# (do not use in production)
# BUILDER_AUTH_DISABLED=1


# --- OpenRouter (builder agent LLM) -------------------------------------------
#
# Get a key at: https://openrouter.ai/settings/keys
# When set, /api/agent-turn uses OpenRouter instead of template codegen.

OPENROUTER_API_KEY=
# OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free


# --- Supabase (usage tracking for builder + app) --------------------------------
#
# Service role key lets the platform record per-customer token usage in ai_usage.
# Get from Supabase Dashboard → Project Settings → API → service_role

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
