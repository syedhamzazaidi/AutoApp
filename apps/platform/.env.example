# Platform builder — copy to .env: cp .env.example .env
#
# load-env.ts also reads repo root .env, so you can put these there instead.
# See ../../.env.sample for scaffold (Supabase) and other repo-wide vars.

# --- Server -------------------------------------------------------------------

# Port for landing page + builder (default 3001)
# PORT=3001


# --- Database (Better Auth + projects/messages) --------------------------------

DATABASE_URL=postgresql://platform:platform@localhost:5432/platform


# --- Better Auth — Google OAuth for /builder ----------------------------------
#
# Required for Google sign-in on /builder and protected /api/* routes.
# Without these, the server logs warnings and sign-in will not work unless
# BUILDER_AUTH_DISABLED is set.
#
# 1. Generate BETTER_AUTH_SECRET:
#      openssl rand -base64 32
#
# 2. Create OAuth 2.0 credentials (Web application):
#      https://console.cloud.google.com/apis/credentials
#
# 3. Authorized redirect URI (must match BETTER_AUTH_URL):
#      http://localhost:3001/api/auth/callback/google
#    In production, use: https://your-domain/api/auth/callback/google

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local dev only — skip auth on /builder and protected API routes
# (do not use in production)
# BUILDER_AUTH_DISABLED=1


# --- GKE / kind sandbox provisioning -------------------------------------------

# Path to kubeconfig (local kind cluster). In-cluster on GKE this is omitted.
KUBECONFIG=~/.kube/config

# Wildcard preview host suffix: {projectId}.preview.localtest.me (kind) or prod domain
PREVIEW_DOMAIN=preview.localtest.me

# HMAC secret shared between platform and sandbox pods (generate like BETTER_AUTH_SECRET)
SANDBOX_AUTH_SECRET=

# Optional overrides
# SANDBOX_NAMESPACE=endian-sandboxes
# SANDBOX_IMAGE=endian-sandbox:latest
# SANDBOX_URL_OVERRIDE=http://localhost:3002


# --- Vertex AI / Gemini (builder agent LLM) -----------------------------------
#
# Builder calls Gemini via Vertex AI (GCP credits). Auth:
#   Local:  gcloud auth application-default login
#           or GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/.secrets/gcp-admin-sa.json
#           (github-deploy SA needs roles/aiplatform.user — see infra/README.md)
#   GKE:    Workload Identity on platform-runtime-<env> + roles/aiplatform.user
#
# Disable live Gemini (template fallback / unit tests):
#   GEMINI_DISABLED=1
#   VERTEX_DISABLED=1   — alias for GEMINI_DISABLED
#
# Smoke from repo root (use absolute credentials path — package cwd differs):
#   GOOGLE_APPLICATION_CREDENTIALS=$PWD/.secrets/gcp-admin-sa.json pnpm test:vertex-model
#
# OPENROUTER_API_KEY / OPENROUTER_MODEL are NOT required for the builder.
# (Plant Pal edge functions may still use OpenRouter separately.)

GCP_PROJECT_ID=project-5be3cb47-0a28-4053-b3a
VERTEX_LOCATION=global
VERTEX_MODEL=gemini-2.5-flash-lite
# GEMINI_DISABLED=1
# VERTEX_DISABLED=1
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/.secrets/gcp-admin-sa.json


# --- Supabase (usage tracking + sandbox VITE_* injection) -----------------------

SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Injected into sandbox pod Secrets for generated app client env
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
