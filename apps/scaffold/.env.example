# Scaffold app (Plant Pal) — copy to .env: cp .env.example .env
# Or copy from repo root: cp ../../.env.sample .env
#
# This file is for Vite + Supabase client keys only.
# Builder Google OAuth credentials are separate — see apps/platform/.env.example

# Supabase — client-side keys only (never commit real secrets)
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Edge function secrets (set in Supabase dashboard, not here):
# SUPABASE_SECRET_KEY
# OPENROUTER_API_KEY
# OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
