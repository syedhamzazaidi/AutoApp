# =============================================================================
# Endian — environment variables (copy & edit)
# =============================================================================
#
# Quick start (local dev):
#
#   cp .env.sample apps/scaffold/.env
#   # fill in VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY
#
# Get Supabase values from:
#   Dashboard → Project Settings → API
#   - Project URL  → VITE_SUPABASE_URL
#   - anon public  → VITE_SUPABASE_ANON_KEY  (safe for browser)
#
# NEVER put service_role or third-party API keys in VITE_* vars — those belong
# in Supabase Edge Function secrets (see section below).
#
# =============================================================================


# --- Scaffold app (Vite / React) — copy these to apps/scaffold/.env -----------

# Supabase project URL (e.g. https://abcdefghijklmnop.supabase.co)
VITE_SUPABASE_URL=

# Publishable anon key (starts with eyJ… — NOT the service_role key)
VITE_SUPABASE_ANON_KEY=


# --- Platform builder UI (optional) — apps/platform/.env if you add one -----

# Port for the landing page + builder server (default 3001)
# PORT=3001

# URL of the running scaffold dev server (used by builder preview iframe)
# SCAFFOLD_PREVIEW_URL=http://localhost:5173


# --- Supabase CLI (local linking & deploy) ------------------------------------
# Used by: supabase link, supabase db push, supabase functions deploy
# Create a token at: https://supabase.com/dashboard/account/tokens

# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=your-project-ref


# --- Edge function secrets (Supabase Dashboard only — NOT in apps/scaffold/.env)
#
# Set in: Dashboard → Project Settings → Edge Functions → Secrets
#   or:   supabase secrets set KEY=value --project-ref <ref>
#
# Required for admin-metrics and analyze-plant edge functions:
#   SUPABASE_URL              (auto-injected by Supabase at runtime)
#   SUPABASE_SERVICE_ROLE_KEY (auto-injected by Supabase at runtime)
#
# Optional — real AI instead of mock responses:
#   LOVABLE_API_KEY=your-gateway-key


# --- GitHub Actions (repository secrets — not a local .env file) --------------
#
# For .github/workflows/deploy.yml:
#   SUPABASE_ACCESS_TOKEN
#   SUPABASE_PROJECT_REF
#
# For Vercel (Project Settings → Environment Variables):
#   VITE_SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY
