{
  "name": "autoapp",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "blocks:validate-manifest": "pnpm --filter @app/block-registry validate",
    "blocks:activate": "pnpm --filter @app/block-registry activate",
    "blocks:deactivate": "pnpm --filter @app/block-registry deactivate",
    "policy:check-protected-paths": "node scripts/check-protected-paths.mjs",
    "export:scaffold": "node scripts/export-scaffold.mjs",
    "test:openrouter-model": "pnpm --filter @app/ai-gateway test:model",
    "try:free-models": "pnpm --filter @app/ai-gateway try:free-models"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
